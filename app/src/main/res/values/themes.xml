<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base app theme - delegates colors to Compose -->
    <style name="Theme.SmartCallBlocker" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/white</item>
        <item name="android:statusBarColor">@color/status_bar_light</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
    </style>

    <!-- Splash Screen using Android 12+ API -->
    <style name="Theme.SmartCallBlocker.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_primary_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_shield</item>
        <item name="windowSplashScreenAnimationDuration">800</item>
        <item name="postSplashScreenTheme">@style/Theme.SmartCallBlocker</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/brand_primary_dark</item>
    </style>

</resources>
